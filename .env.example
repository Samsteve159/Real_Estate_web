# Copy to .env at the REPO ROOT and fill in. Never commit .env (it is gitignored).
# The Hono API loads this file via api/src/anthropic.ts (dotenv) from the repo root — NOT api/.env.

# Anthropic key that powers Instant Valuation + the AI Concierge (server-side only; never in the browser bundle).
# Use the "Manifest Real Estate" WORKSPACE key (Console -> Workspaces -> Manifest Real Estate -> API keys)
# so all spend attributes to that workspace for per-project invoicing of Akshay.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default port for the Hono API (default 8787)
PORT=8787

# Optional (prod/deploy): comma-separated origins allowed to call the API
ALLOWED_ORIGINS=

# Optional: bearer token guarding the /stats endpoint
STATS_TOKEN=
